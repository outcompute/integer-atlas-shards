{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://integer-atlas/schema/work-order.schema.json",
  "title": "Integer Atlas work order",
  "description": "A planned-but-uncomputed shard: a range and the columns to compute. The algorithm version is stamped on the resulting manifest by atlas-algos, not pinned here.",
  "type": "object",
  "required": ["id", "range_start", "range_end", "columns"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "table": { "type": "string", "default": "numbers" },
    "range_start": { "type": "integer" },
    "range_end": { "type": "integer" },
    "columns": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "algorithm_release": { "type": "string" },
    "expected_row_count": { "type": "integer", "minimum": 0 },
    "cost_estimate_seconds": { "type": "number", "minimum": 0 }
  }
}
